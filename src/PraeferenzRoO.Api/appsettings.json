{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cache": {
    "SlidingExpirationMinutes": 30,
    "AbsoluteExpirationMinutes": 120
  },
  "Localization": {
    "DefaultCulture": "en-US",
    "SupportedCultures": [ "en-US", "de-DE" ]
  },
  "MultiTenancy": {
    "TenantHeader": "X-Tenant-Id"
  }
}
